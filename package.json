{
  "name": "formation-platform",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo — NestJS backend + Next.js frontend (npm workspaces)",
  "license": "UNLICENSED",
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "dev": "npm run kill && concurrently -n BACKEND,FRONTEND -c bgBlue.bold,bgMagenta.bold \"npm run start:dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "kill": "(fuser -k 3000/tcp 2>/dev/null; fuser -k 3001/tcp 2>/dev/null; rm -f frontend/.next/dev/lock 2>/dev/null; sleep 1) || true",
    "build": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "start:prod": "npm run start:prod --workspace=backend",
    "test": "npm run test --workspace=backend",
    "test:e2e": "npm run test:e2e --workspace=backend",
    "lint": "npm run lint --workspace=backend",
    "format": "npm run format --workspace=backend",
    "generate:mocks": "npm run generate:mocks --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=20"
  }
}
